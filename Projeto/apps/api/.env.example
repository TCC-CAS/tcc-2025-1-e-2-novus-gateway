NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://varzeapro:varzeapro_dev@localhost:5432/varzeapro
JWT_SECRET=change-me-to-a-real-secret-at-least-32-chars-long
BETTER_AUTH_SECRET=change-me-to-a-real-secret-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# --- S3-compatible storage (AWS S3 / Cloudflare R2 / MinIO) ---
# Set credentials when ready to connect your bucket.
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=varzeapro-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional CDN base URL (e.g., https://cdn.varzeapro.com). Leave empty for presigned URLs.
S3_PUBLIC_URL=
# Use path-style URLs for MinIO. Set to "true" for MinIO, "false" for AWS/R2.
S3_USE_PATH_STYLE=false

# --- Image processing ---
IMAGE_MAX_SIZE_MB=10
IMAGE_MAX_DIMENSION=4000
PRESIGNED_URL_TTL_SECONDS=3600

# --- Upload rate limiting ---
UPLOAD_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_WINDOW_MINUTES=60
