NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://varzeapro:varzeapro_dev@localhost:5432/varzeapro
JWT_SECRET=change-me-to-a-real-secret-at-least-32-chars-long
BETTER_AUTH_SECRET=change-me-to-a-real-secret-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# --- S3-compatible storage (AWS S3 / Cloudflare R2 / MinIO) ---
# Set credentials when ready to connect your bucket.
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=varzeapro-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional CDN base URL (e.g., https://cdn.varzeapro.com). Leave empty for presigned URLs.
S3_PUBLIC_URL=
# Use path-style URLs for MinIO. Set to "true" for MinIO, "false" for AWS/R2.
S3_USE_PATH_STYLE=false

# --- Rekognition image moderation ---
REKOGNITION_ENABLED=true
REKOGNITION_REGION=us-east-1
REKOGNITION_MIN_CONFIDENCE=80
REKOGNITION_BLOCKED_LABELS=Explicit Nudity,Violence,Blood & Gore,Visually Disturbing,Drugs,Alcohol,Tobacco,Gambling,Hate Symbols,Sexual Activity,Suggestive

# --- Image processing ---
IMAGE_MAX_SIZE_MB=10
IMAGE_MAX_DIMENSION=4000
PRESIGNED_URL_TTL_SECONDS=3600

# --- Upload rate limiting ---
UPLOAD_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_WINDOW_MINUTES=60

# --- Payments ---
# "mock" = plano ativado direto, sem gateway (padrão para dev)
# "mercadopago" = checkout via MercadoPago sandbox
PAYMENT_MODE=mock
MERCADOPAGO_ACCESS_TOKEN=your-sandbox-access-token
MERCADOPAGO_WEBHOOK_URL=https://api.yourdomain.com/api/webhooks/mercadopago

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
